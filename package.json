{
  "name": "andwell-innovation",
  "version": "1.0.0",
  "private": true,
  "description": "Andwell Innovation command center for competitive intelligence, growth planning, staffing, launch execution, and board-ready strategy.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "postbuild": "node scripts/patch-standalone-server.js",
    "build:next": "next build",
    "build:hostinger": "next build",
    "start:custom": "node server.js",
    "build:strict": "CIH_STRICT_BUILD=1 next build",
    "typecheck": "tsc --noEmit",
    "typecheck:strict": "tsc --noEmit --strict --noUnusedLocals",
    "lint": "eslint . --ext .ts,.tsx --max-warnings 20",
    "lint:report": "eslint . --ext .ts,.tsx -f json -o eslint-report.json",
    "format": "prettier --write \"**/*.{ts,tsx,json,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,css}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "ci": "npm run typecheck:strict && npm run lint && npm run test",
    "start": "node server.js",
    "serve": "node server.js",
    "hostinger:start": "node server.js",
    "start:hostinger": "node server.js"
  },
  "dependencies": {
    "@auth/supabase-adapter": "^1.11.2",
    "@supabase/supabase-js": "^2.105.4",
    "@tailwindcss/postcss": "^4.3.0",
    "@xenova/transformers": "^2.17.2",
    "cheerio": "1.0.0",
    "framer-motion": "^12.39.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.16.0",
    "mongodb": "^6.0.0",
    "next": "^15.5.18",
    "next-auth": "^4.24.14",
    "pdf-parse": "^2.4.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.8.1",
    "tailwindcss": "^4.3.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/eslint": "^9.6.1",
    "@types/node": "^20.17.10",
    "@types/react": "^18.3.29",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "typescript": "^5.7.2",
    "vitest": "^4.1.7"
  },
  "overrides": {
    "postcss": "8.5.10"
  },
  "engines": {
    "node": "20.x"
  }
}
